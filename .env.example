# Copy this to .env and fill in your keys

# Anthropic (for lyrics + hashtag generation)
ANTHROPIC_API_KEY=your_key_here

# NewsAPI (https://newsapi.org - free tier)
NEWS_API_KEY=your_key_here

# OpenAI (for DALL-E 3 image generation)
OPENAI_API_KEY=your_key_here

# Suno - cookie from logged-in browser session on suno.ai
# Open DevTools → Application → Cookies → copy the full cookie string
SUNO_COOKIE=your_cookie_here
# Base URL for suno-api Docker container (default: http://localhost:3000)
SUNO_API_BASE=http://localhost:3000

# TikTok Content Posting API (https://developers.tiktok.com)
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_REFRESH_TOKEN=your_refresh_token_here
