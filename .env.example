# Copy this to .env and fill in your keys

# Anthropic (optional — not currently used in pipeline)
ANTHROPIC_API_KEY=your_key_here

# NewsAPI (https://newsapi.org - free tier)
NEWS_API_KEY=your_key_here

# OpenAI (passthrough key for Ollama — set to "ollama" if no real key)
OPENAI_API_KEY=ollama

# sunoapi.org — hosted Suno API (https://sunoapi.org)
SUNOAPI_KEY=your_key_here
# Optional: override base URL (default: https://api.sunoapi.org)
# SUNOAPI_BASE=https://api.sunoapi.org

# Runway ML (https://runwayml.com)
RUNWAYML_API_SECRET=your_key_here

# TikTok Content Posting API (https://developers.tiktok.com)
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_REFRESH_TOKEN=your_refresh_token_here

# xAI / Grok (optional — for --provider grok lyrics generation)
XAI_API_KEY=your_key_here

# Ollama (local LLM — must be running with gemma3 pulled)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3

# Supabase (optional — enables cloud dashboard sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
